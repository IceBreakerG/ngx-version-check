{
  "name": "version-check-demo",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/version-check-demo/src",
  "prefix": "app",
  "generators": {
    "@schematics/angular:component": {
      "style": "scss"
    }
  },
  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:application",
      "dependsOn": [
        {
          "target": "build",
          "projects": [
            "ngx-version-check"
          ]
        }
      ],
      "options": {
        "outputPath": {
          "base": "dist/version-check-demo"
        },
        "index": "apps/version-check-demo/src/index.html",
        "polyfills": [
          "apps/version-check-demo/src/polyfills.ts"
        ],
        "tsConfig": "apps/version-check-demo/tsconfig.app.json",
        "aot": true,
        "assets": [
          "apps/version-check-demo/src/favicon.ico",
          "apps/version-check-demo/src/assets",
          "apps/version-check-demo/src/version.json",
          {
            "glob": "**/*",
            "input": "./node_modules/ngx-version-check/assets",
            "output": "/"
          }
        ],
        "styles": [
          "apps/version-check-demo/src/styles.scss"
        ],
        "scripts": [],
        "browser": "apps/version-check-demo/src/main.ts"
      },
      "configurations": {
        "production": {
          "fileReplacements": [
            {
              "replace": "apps/version-check-demo/src/environments/environment.ts",
              "with": "apps/version-check-demo/src/environments/environment.prod.ts"
            }
          ],
          "optimization": true,
          "outputHashing": "all",
          "sourceMap": false,
          "namedChunks": false,
          "extractLicenses": true,
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "2mb",
              "maximumError": "5mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "6kb",
              "maximumError": "10kb"
            }
          ]
        }
      },
      "outputs": [
        "{options.outputPath.base}"
      ]
    },
    "serve": {
      "executor": "@angular-devkit/build-angular:dev-server",
      "options": {
        "buildTarget": "version-check-demo:build"
      },
      "configurations": {
        "production": {
          "buildTarget": "version-check-demo:build:production"
        }
      }
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "buildTarget": "version-check-demo:build"
      }
    },
    "test": {
      "executor": "@angular-devkit/build-angular:karma",
      "options": {
        "main": "apps/version-check-demo/src/test.ts",
        "polyfills": "apps/version-check-demo/src/polyfills.ts",
        "tsConfig": "apps/version-check-demo/tsconfig.spec.json",
        "karmaConfig": "apps/version-check-demo/karma.conf.js",
        "assets": [
          "apps/version-check-demo/src/favicon.ico",
          "apps/version-check-demo/src/assets"
        ],
        "styles": [
          "apps/version-check-demo/src/styles.scss"
        ],
        "scripts": []
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
