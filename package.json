{
  "name": "ngx-version-check",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --configuration production",
    "build-dev": "ng build",
    "test": "ng test ngx-version-check --watch=false --browsers=ChromeHeadless",
    "test-library": "ng test version-check --watch=false --browsers=ChromeHeadless",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "dev": "ng serve --host=0.0.0.0 --disable-host-check",
    "create-package": "npm run build-library && npm run package-library",
    "create-package-unix": "npm run build-library-unix && npm run package-library",
    "build-library": "ng build version-check --configuration production",
    "build-library-unix": "ng build version-check --configuration production",
    "postbuild": "node ./node_modules/ngx-version-check/build/post-build.js ngx-version-check",
    "postbuild-library": "node -e \"const fs=require('fs');fs.cpSync('projects/version-check/src/build','dist/version-check/build',{recursive:true,force:true});fs.cpSync('projects/version-check/src/assets','dist/version-check/assets',{recursive:true,force:true});\"",
    "postbuild-library-unix": "cp -R projects/version-check/src/build dist/version-check/build && cp -R projects/version-check/src/assets dist/version-check/assets",
    "package-library": "cd dist/version-check && npm pack"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.2.20",
    "@angular/common": "^19.2.20",
    "@angular/compiler": "^19.2.20",
    "@angular/core": "^19.2.20",
    "@angular/forms": "^19.2.20",
    "@angular/platform-browser": "^19.2.20",
    "@angular/platform-browser-dynamic": "^19.2.20",
    "@angular/router": "^19.2.20",
    "moment": "^2.24.0",
    "ngx-version-check": "file:dist/version-check/ngx-version-check-1.2.0.tgz",
    "rxjs": "~6.6.2",
    "tslib": "^2.3.1",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.23",
    "@angular/cli": "^19.2.23",
    "@angular/compiler-cli": "^19.2.20",
    "@angular/language-service": "^19.2.20",
    "@types/jasmine": "~3.3.8",
    "@types/jasminewd2": "~2.0.3",
    "@types/node": "^17.0.23",
    "codelyzer": "^6.0.0",
    "jasmine-core": "~3.10.1",
    "jasmine-spec-reporter": "~5.0.0",
    "karma": "~6.3.16",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage-istanbul-reporter": "~3.0.2",
    "karma-jasmine": "~3.3.0",
    "karma-jasmine-html-reporter": "^1.5.0",
    "ng-packagr": "^19.2.2",
    "protractor": "~7.0.0",
    "ts-node": "~7.0.0",
    "tslint": "~6.1.0",
    "typescript": "~5.8.3"
  }
}